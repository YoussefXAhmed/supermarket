# ERPNext site URL (desk, images, print links)
VITE_ERPNEXT_URL=http://127.0.0.1:8000

# Optional: override REST API base (defaults to same-origin in dev, VITE_ERPNEXT_URL in production)
# VITE_ERP_API_BASE=

# Optional: override printview origin (defaults to VITE_ERPNEXT_URL)
# VITE_ERP_PRINT_BASE=
