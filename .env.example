# ERPNext site URL (desk, images, print links)
VITE_ERPNEXT_URL=http://127.0.0.1:8000

# Optional: override REST API base (defaults to same-origin in dev, VITE_ERPNEXT_URL in production)
# VITE_ERP_API_BASE=

# Optional: override printview origin (defaults to VITE_ERPNEXT_URL)
# VITE_ERP_PRINT_BASE=

# ─── Observability (Sentry / GlitchTip) ─────────────────────────────────────
# Set to a Sentry-compatible DSN to enable client-side error capture. Leave
# blank to disable (dev default — all observability functions become no-ops).
# Works with hosted Sentry or self-hosted GlitchTip (same protocol).
# VITE_SENTRY_DSN=

# Environment tag (defaults to Vite's MODE: development / production)
# VITE_SENTRY_ENV=production

# Release identifier — recommended for sourcemap stack-trace matching.
# Typically set to the git SHA at build time:
#   VITE_SENTRY_RELEASE=$(git rev-parse --short HEAD) npm run build
# VITE_SENTRY_RELEASE=
